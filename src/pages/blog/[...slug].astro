---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content, headings } = await render(post);

// Reading estimate from the raw markdown body — Chinese chars + Latin words.
const body = post.body ?? '';
const cnChars = (body.match(/[一-龥]/g) ?? []).length;
const enWords = (body.replace(/[一-龥]/g, ' ').match(/[A-Za-z0-9]+/g) ?? []).length;
const wordCount = cnChars + enWords;
const readingMinutes = Math.max(1, Math.round(cnChars / 400 + enWords / 200));
---

<BlogPost {...post.data} headings={headings} showComments readingMinutes={readingMinutes} wordCount={wordCount} currentId={post.id}>
	<Content />
</BlogPost>
