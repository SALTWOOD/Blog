---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_ALTERNATE_NAME, SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { authorPerson } from '../lib/schema';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const websiteJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: SITE_TITLE,
	alternateName: SITE_ALTERNATE_NAME,
	url: new URL('/', Astro.site).href,
	description: SITE_DESCRIPTION,
	inLanguage: 'zh-CN',
	publisher: authorPerson(Astro.site),
};
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)} />
		<style>
			main {
				width: 1040px;
				max-width: calc(100% - 2em);
			}

			/* Hero — logbook landing */
			.hero {
				min-height: 100vh;
				min-height: 100svh;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				text-align: center;
				padding: 6rem 1.5rem 4rem;
				box-sizing: border-box;
				position: relative;
			}
			.hero::before {
				content: '';
				position: absolute;
				inset: 0;
				background: radial-gradient(
					circle at 50% 38%,
					rgba(var(--sea-rgb), 0.1) 0%,
					transparent 62%
				);
				pointer-events: none;
			}
			.bearing {
				position: relative;
				display: inline-flex;
				align-items: center;
				gap: 0.6em;
				font-family: var(--font-mono);
				font-size: 0.82rem;
				letter-spacing: 0.18em;
				text-transform: uppercase;
				color: var(--brass);
				margin-bottom: 1.5rem;
			}
			.bearing::before,
			.bearing::after {
				content: '';
				width: 2.2rem;
				height: 1px;
				background: linear-gradient(to right, transparent, var(--brass));
			}
			.bearing::after {
				background: linear-gradient(to left, transparent, var(--brass));
			}
			.hero h1 {
				position: relative;
				font-weight: 600;
				letter-spacing: -0.01em;
				color: rgb(var(--ink));
				margin: 0 0 1.25rem;
				line-height: 1.12;
				font-size: clamp(2.6rem, 7vw, 4.2rem);
			}
			.hero .kicker {
				position: relative;
				display: block;
				font-family: var(--font-display);
				font-style: italic;
				font-weight: 400;
				color: var(--sea);
				font-size: clamp(1rem, 2vw, 1.25rem);
				margin-bottom: 0.75rem;
				letter-spacing: 0;
			}
			.hero p.lede {
				position: relative;
				max-width: 40rem;
				font-size: 1.1rem;
				line-height: 1.7;
				color: rgb(var(--ink-soft));
				margin: 0 0 2.25rem;
			}
			.hero-cta {
				position: relative;
				display: inline-flex;
				align-items: center;
				gap: 0.55rem;
				padding: 0.8rem 1.6rem;
				border-radius: var(--r-pill);
				background: var(--brass);
				color: #fff7e8;
				font-family: var(--font-body);
				font-weight: 600;
				text-decoration: none;
				letter-spacing: 0.02em;
				transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
				box-shadow: 0 6px 20px rgba(var(--brass-rgb), 0.35);
			}
			.hero-cta:hover {
				color: #fff7e8;
				background: var(--sea-deep);
				transform: translateY(-2px);
				box-shadow: 0 10px 28px rgba(var(--sea-rgb), 0.4);
			}
			.hero-cta:active {
				transform: scale(0.97);
			}
			.hero-cta svg {
				width: 1.05em;
				height: 1.05em;
				transition: transform 0.2s ease;
			}
			.hero-cta:hover svg {
				transform: translateY(2px);
			}

			/* Staggered entrance for the landing */
			@media (prefers-reduced-motion: no-preference) {
				.hero > * {
					animation: risein 0.55s cubic-bezier(0.2, 0.7, 0.2, 1) both;
				}
				.hero > *:nth-child(1) {
					animation-delay: 0.05s;
				}
				.hero > *:nth-child(2) {
					animation-delay: 0.15s;
				}
				.hero > *:nth-child(3) {
					animation-delay: 0.25s;
				}
				.hero > *:nth-child(4) {
					animation-delay: 0.35s;
				}
			}

			/* Log section heading */
			.log-head {
				display: flex;
				align-items: baseline;
				justify-content: space-between;
				gap: 1em;
				margin: 0 0 1.75rem;
				padding-bottom: 0.75rem;
				border-bottom: 1px solid var(--rule);
			}
			.log-head h2 {
				margin: 0;
				font-size: 1.3rem;
				font-weight: 600;
				color: rgb(var(--ink));
			}
			.log-head .count {
				font-family: var(--font-mono);
				font-size: 0.85rem;
				color: rgb(var(--ink-soft));
			}

			/* Post list — dated log entries, CSS-columns masonry */
			ul.entries {
				column-count: 2;
				column-gap: 1.75rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul.entries li {
				break-inside: avoid;
				page-break-inside: avoid;
				margin-bottom: 1.75rem;
			}
			.entry {
				display: block;
				box-sizing: border-box;
				text-decoration: none;
				background: var(--paper-raised);
				border: 1px solid var(--rule);
				border-left: 3px solid transparent;
				border-radius: var(--r-md);
				padding: 1.1rem 1.25rem;
				transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
				height: 100%;
			}
			.entry:hover {
				transform: translateY(-3px);
				box-shadow: var(--shadow-card);
				border-left-color: var(--brass);
			}
			.entry :global(img) {
				width: calc(100% + 2.5rem);
				height: auto;
				margin: -1.1rem -1.25rem 1rem;
				display: block;
				border-radius: var(--r-md) var(--r-md) 0 0;
				border-bottom: 1px solid var(--rule);
			}
			.entry-meta {
				display: flex;
				align-items: center;
				gap: 0.5em;
				font-family: var(--font-mono);
				font-size: 0.76rem;
				letter-spacing: 0.02em;
				color: rgb(var(--ink-soft));
				margin-bottom: 0.4rem;
				text-transform: uppercase;
			}
			.entry-meta .cat {
				color: var(--sea);
			}
			.entry-meta .dot {
				color: var(--rule);
			}
			.title {
				margin: 0;
				color: rgb(var(--ink));
				line-height: 1.3;
				font-size: 1.35rem;
				font-family: var(--font-display);
				font-weight: 600;
				transition: color 0.15s ease;
			}
			.desc {
				margin: 0.55rem 0 0;
				color: rgb(var(--ink-soft));
				font-size: 0.92rem;
				line-height: 1.6;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.entry:hover .title {
				color: var(--sea);
			}
			[data-theme='dark'] .entry:hover .title {
				color: var(--brass-soft);
			}
			@media (max-width: 720px) {
				ul.entries {
					column-count: 1;
					column-gap: 0;
				}
				.hero {
					padding: 5rem 1.25rem 3rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<section class="hero">
			<span class="bearing">32.790°N · 79.909°W</span>
			<h1>
				<span class="kicker">Saltwood&apos;s Log</span>
				{SITE_TITLE}
			</h1>
			<p class="lede">{SITE_DESCRIPTION}</p>
			<a class="hero-cta" href="#content-root">
				浏览文章
				<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<polyline points="6 9 12 15 18 9"></polyline>
				</svg>
			</a>
		</section>
		<main id="content-root">
			<section>
				<div class="log-head">
					<h2>航行日志</h2>
					<span class="count">{posts.length} 篇记录</span>
				</div>
				<ul class="entries">
					{
						posts.map((post) => (
							<li>
								<a class="entry" href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt={post.data.title} />
									)}
									<div class="entry-meta">
										<time><FormattedDate date={post.data.pubDate} /></time>
										{post.data.category && (
											<>
												<span class="dot">/</span>
												<span class="cat">{post.data.category}</span>
											</>
										)}
									</div>
									<h2 class="title">{post.data.title}</h2>
									{post.data.description && <p class="desc">{post.data.description}</p>}
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
