---
import fs from 'node:fs';
import path from 'node:path';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FriendCard from '../components/FriendCard.astro';
import Comments from '../components/Comments.astro';

const linksPath = path.resolve('src/links/links.json');
let friendData: Array<{ slug: string; name: string; url: string; description: string }> = [];
if (fs.existsSync(linksPath)) {
	try {
		const raw = JSON.parse(fs.readFileSync(linksPath, 'utf-8'));
		if (Array.isArray(raw)) friendData = raw;
	} catch { /* file corrupt, use empty */ }
}

const avatars = import.meta.glob<{ default: ImageMetadata }>(
	'../assets/friends/*.webp',
	{ eager: true },
);

const friends = friendData
	.map((f) => ({
		slug: f.slug,
		name: f.name,
		url: f.url,
		desc: f.description,
		avatar: avatars[`../assets/friends/${f.slug}.webp`]?.default,
	}));
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title="友链 - 盐木的小破窝" description="盐木的友链" />
		<style>
			main {
				width: 1100px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
			}
			h1 {
				color: rgb(var(--black));
			}
			.friends-grid {
				list-style: none;
				margin: 1.5rem 0 0;
				padding: 0;
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
				gap: 1.5rem;
			}
			.friends-grid li {
				margin: 0;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>友链</h1>
			<ul class="friends-grid">
				{friends.map((f) => (
					<li>
						<FriendCard {...f} />
					</li>
				))}
			</ul>
			<script is:inline>
				// 每次刷新都随机打乱友链顺序
				const grid = document.querySelector('.friends-grid');
				if (grid) {
					const items = Array.from(grid.children);
					for (let i = items.length - 1; i > 0; i--) {
						const j = Math.floor(Math.random() * (i + 1));
						[items[i], items[j]] = [items[j], items[i]];
					}
					items.forEach((item) => grid.appendChild(item));
				}
			</script>
			<hr>
			<span>添加友链，请在下方留言或访问<a href="https://github.com/SALTWOOD/Blog">此处</a></span>
			<Comments />
		</main>
		<Footer />
	</body>
</html>
