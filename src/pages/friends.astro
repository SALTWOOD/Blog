---
import fs from 'node:fs';
import path from 'node:path';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FriendCard from '../components/FriendCard.astro';
import Comments from '../components/Comments.astro';

const linksPath = path.resolve('src/links/links.json');
let friendData: Array<{ slug: string; name: string; url: string; description: string }> = [];
if (fs.existsSync(linksPath)) {
	try {
		const raw = JSON.parse(fs.readFileSync(linksPath, 'utf-8'));
		if (Array.isArray(raw)) friendData = raw;
	} catch { /* file corrupt, use empty */ }
}

const avatars = import.meta.glob<{ default: ImageMetadata }>(
	'../assets/friends/*.webp',
	{ eager: true },
);

const friends = friendData
	.map((f) => ({
		slug: f.slug,
		name: f.name,
		url: f.url,
		desc: f.description,
		avatar: avatars[`../assets/friends/${f.slug}.webp`]?.default,
	}));
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title="友链 - 盐木的小破窝" description="盐木的友链" />
		<style>
			main {
				width: 1100px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 3em 1em;
			}
			.friends-grid {
				list-style: none;
				margin: 0;
				padding: 0;
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: 1.25rem;
			}
			.friends-grid li {
				margin: 0;
			}
			.note {
				margin-top: 2.5rem;
				padding-top: 1.5rem;
				border-top: 1px solid var(--rule);
				color: rgb(var(--ink-soft));
				font-size: 0.92rem;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<header class="page-head">
				<span class="eyebrow">Shipmates · 友邻</span>
				<h1>友链</h1>
				<p class="lede">同行者们的港湾。顺序每次刷新随机打乱。</p>
			</header>
			<ul class="friends-grid">
				{friends.map((f) => (
					<li>
						<FriendCard {...f} />
					</li>
				))}
			</ul>
			<script is:inline>
				// 每次刷新都随机打乱友链顺序
				const grid = document.querySelector('.friends-grid');
				if (grid) {
					const items = Array.from(grid.children);
					for (let i = items.length - 1; i > 0; i--) {
						const j = Math.floor(Math.random() * (i + 1));
						[items[i], items[j]] = [items[j], items[i]];
					}
					items.forEach((item) => grid.appendChild(item));
				}
			</script>
			<p class="note">添加友链，请在下方留言或访问<a href="https://github.com/SALTWOOD/Blog">此处</a>。</p>
			<Comments />
		</main>
		<Footer />
	</body>
</html>
