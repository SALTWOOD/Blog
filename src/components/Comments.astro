---
// ========================================
// REMARK42 CONFIGURATION
// Docs: https://remark42.com/docs/getting-started/installation/
//
// These values must match your Remark42 backend:
//   - REMARK_URL:  the --url passed to the remark42 server (REMARK_URL)
//   - REMARK_SITE_ID: the --site passed to the remark42 server ("remark" by default)
//
// Make sure "ski" (or whatever you set below) is included in the backend's
// --site/--sites list, otherwise comments won't load.
// ========================================
const REMARK_URL = 'https://comments.ski.ink';
const REMARK_SITE_ID = 'blog';
---

<section class="comments" data-pagefind-ignore>
	<h2 class="comments-title">评论</h2>
	<div id="remark42">Comments loading...</div>
	<script is:inline define:vars={{ REMARK_URL, REMARK_SITE_ID }} data-astro-rerun>
		// Refresh remark_config on every arrival (incl. client-side swaps via
		// <ClientRouter />) so the widget picks up the current theme.
		window.remark_config = {
			host: REMARK_URL,
			site_id: REMARK_SITE_ID,
			components: ['embed'],
			theme: document.documentElement.dataset.theme || 'light',
			locale: 'zh',
		};

		(function () {
			var node = document.getElementById('remark42');
			if (!node) return;
			// SPA navigation: the library is already loaded, so mount a fresh
			// widget into the new (empty) #remark42 node instead of re-injecting
			// the loader script.
			if (window.REMARK42 && typeof window.REMARK42.createWidget === 'function') {
				node.innerHTML = '';
				window.REMARK42.createWidget({ node: node, component: 'embed' });
				return;
			}
			// First load: inject the Remark42 embed script, which auto-creates
			// the widget once it finishes loading.
			!(function (e, n) {
				for (var o = 0; o < e.length; o++) {
					var r = n.createElement('script'),
						c = '.js',
						d = n.head || n.body;
					if ('noModule' in r) {
						r.type = 'module';
						c = '.mjs';
					} else {
						r.async = true;
					}
					r.defer = true;
					r.src = remark_config.host + '/web/' + e[o] + c;
					d.appendChild(r);
				}
			})(remark_config.components || ['embed'], document);
		})();
	</script>
	<script is:inline data-astro-rerun>
		// Sync Remark42 theme with the site's theme system. Registered once —
		// the listener lives on window, which survives client-side swaps.
		if (!window.__remarkThemeSynced) {
			window.__remarkThemeSynced = true;
			window.addEventListener('theme-change', function () {
				if (window.REMARK42 && window.REMARK42.changeTheme) {
					var currentTheme = document.documentElement.dataset.theme || 'light';
					window.REMARK42.changeTheme(currentTheme);
				}
			});
		}
	</script>
</section>

<style>
	.comments {
		margin-top: 3em;
		padding-top: 2em;
		border-top: 1px solid var(--rule);
	}
	.comments-title {
		font-family: var(--font-display);
		font-size: 1.4rem;
		font-weight: 600;
		margin-bottom: 1em;
	}
</style>
