---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
import BgToggle from './BgToggle.astro';

// Replicate HeaderLink's active logic for the plain <a> used in the mobile menu.
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const subpath = pathname.match(/[^/]+/g);
const mobileLinks = [
	{ href: '/', label: '文章' },
	{ href: '/tags', label: '标签' },
	{ href: 'https://travellings.cn', label: '开往' },
	{ href: '/about', label: '关于' },
	{ href: '/friends', label: '友链' },
];
const isActive = (href: string) =>
	href === pathname || href === `/${subpath?.[0] || ''}`;
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">文章</HeaderLink>
			<HeaderLink href="/tags">标签</HeaderLink>
			<HeaderLink href="https://travellings.cn">开往</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
			<HeaderLink href="/friends">友链</HeaderLink>
		</div>
		<div class="social-links">
			<div class="toggle-slot" data-toggle-slot="desktop">
				<BgToggle />
				<ThemeToggle />
			</div>
			<a href="https://github.com/SALTWOOD" target="_blank">
				<span class="sr-only">GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
		</div>
		<button
			id="menu-toggle"
			class="menu-toggle"
			type="button"
			aria-label="菜单"
			aria-expanded="false"
			aria-controls="mobile-menu"
		>
			<svg
				xmlns="http://www.w3.org/2000/svg"
				width="24"
				height="24"
				viewBox="0 0 24 24"
				fill="none"
				stroke="currentColor"
				stroke-width="2"
				stroke-linecap="round"
				aria-hidden="true"
			>
				<line x1="3" y1="6" x2="21" y2="6"></line>
				<line x1="3" y1="12" x2="21" y2="12"></line>
				<line x1="3" y1="18" x2="21" y2="18"></line>
			</svg>
		</button>
	</nav>
	<div id="mobile-menu" class="mobile-menu" hidden>
		{mobileLinks.map((link) => (
			<a href={link.href} class:list={['mobile-link', { active: isActive(link.href) }]}>
				{link.label}
			</a>
		))}
		<div class="mobile-actions">
			<div class="toggle-slot" data-toggle-slot="mobile"></div>
			<a href="https://github.com/SALTWOOD" target="_blank" class="mobile-github">
				<span class="sr-only">GitHub</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
		</div>
	</div>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 40;
		margin: 0;
		padding: 0 1.5em;
		background: var(--bg-header);
		-webkit-backdrop-filter: blur(10px) saturate(1.2);
		backdrop-filter: blur(10px) saturate(1.2);
		border-top: 3px solid var(--brass);
		border-bottom: 1px solid var(--rule);
	}
	h2 {
		margin: 0;
		font-family: var(--font-display);
		font-size: 1.15rem;
		font-weight: 600;
		letter-spacing: -0.01em;
	}
	h2 a {
		display: inline-flex;
		align-items: center;
		gap: 0.45em;
		text-decoration: none;
		color: rgb(var(--ink));
	}
	h2 a::before {
		content: '';
		width: 0.5em;
		height: 0.5em;
		flex-shrink: 0;
		background: var(--brass);
		transform: rotate(45deg);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1em;
		max-width: 64rem;
		margin: 0 auto;
	}
	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.1em;
	}
	nav :global(.internal-links) a {
		padding: 1em 0.7em;
		color: rgb(var(--ink));
		border-bottom: 2px solid transparent;
		text-decoration: none;
		font-size: 0.97rem;
		font-weight: 500;
		transition: color 0.15s ease, border-color 0.15s ease;
	}
	nav :global(.internal-links) a:hover {
		color: var(--sea);
	}
	nav :global(.internal-links) a.active {
		color: var(--sea-deep);
		border-bottom-color: var(--brass);
		font-weight: 600;
	}
	[data-theme='dark'] nav :global(.internal-links) a.active {
		color: var(--brass-soft);
	}
	.social-links,
	.social-links a {
		display: flex;
	}
	.social-links {
		gap: 0.35em;
		align-items: center;
	}
	.social-links a {
		color: rgb(var(--ink));
		padding: 0.5em;
		border-radius: var(--r-sm);
		transition: color 0.15s ease, background 0.15s ease;
	}
	.social-links a:hover {
		color: var(--sea);
		background: rgba(var(--sea-rgb), 0.1);
	}
	.social-links a svg {
		width: 20px;
		height: 20px;
	}
	/* The toggle slot wrapper dissolves so the ThemeToggle button stays a direct
	   flex child of .social-links on desktop (byte-identical layout). It also
	   serves as a stable anchor for reparenting the single toggle instance. */
	.toggle-slot {
		display: contents;
	}
	/* Hamburger button — hidden on desktop, shown on mobile. */
	.menu-toggle {
		display: none;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.5em;
		color: rgb(var(--ink));
		align-items: center;
		justify-content: center;
		border-radius: var(--r-sm);
	}
	.menu-toggle:hover {
		color: var(--sea);
		background: rgba(var(--sea-rgb), 0.1);
	}
	.menu-toggle svg {
		display: block;
	}
	/* Dropdown panel — always hidden on desktop. */
	.mobile-menu {
		display: none;
	}
	@media (max-width: 720px) {
		.internal-links,
		.social-links {
			display: none;
		}
		.menu-toggle {
			display: flex;
		}
		.mobile-menu {
			position: absolute;
			top: calc(100% + 1px);
			right: 0.75em;
			left: 0.75em;
			z-index: 50;
			display: block;
			background: var(--paper-raised);
			border: 1px solid var(--rule);
			border-top: 2px solid var(--brass);
			box-shadow: var(--box-shadow);
			border-radius: var(--r-md);
			padding: 0.4em 0;
			overflow: hidden;
		}
		.mobile-menu[hidden] {
			display: none;
		}
		.mobile-menu .mobile-link {
			display: block;
			box-sizing: border-box;
			min-height: 44px;
			padding: 0.8em 1.1em;
			color: rgb(var(--ink));
			border-bottom: none;
			text-decoration: none;
			font-weight: 500;
		}
		.mobile-menu .mobile-link:hover {
			background: rgba(var(--sea-rgb), 0.08);
			color: var(--sea);
		}
		.mobile-menu .mobile-link.active {
			font-weight: 600;
			color: var(--sea-deep);
			border-left: 3px solid var(--brass);
			padding-left: calc(1.1em - 3px);
		}
		.mobile-actions {
			display: flex;
			align-items: center;
			gap: 0.5em;
			box-sizing: border-box;
			min-height: 44px;
			padding: 0.7em 1.1em;
			margin-top: 0.25em;
			border-top: 1px solid var(--rule);
		}
		.mobile-actions .mobile-github {
			display: flex;
			align-items: center;
		}
	}
</style>
<script is:inline>
	(function () {
		function closeMenu() {
			var panel = document.getElementById('mobile-menu');
			var btn = document.getElementById('menu-toggle');
			if (panel) panel.setAttribute('hidden', '');
			if (btn) btn.setAttribute('aria-expanded', 'false');
		}
		function openMenu() {
			var panel = document.getElementById('mobile-menu');
			var btn = document.getElementById('menu-toggle');
			if (panel) panel.removeAttribute('hidden');
			if (btn) btn.setAttribute('aria-expanded', 'true');
		}
		function relocateToggle() {
			var mobile = window.matchMedia('(max-width: 720px)').matches;
			var slot = document.querySelector(
				mobile ? '[data-toggle-slot="mobile"]' : '[data-toggle-slot="desktop"]'
			);
			if (!slot) return;
			// Move every slotted toggle (theme + background) into the active slot,
			// preserving document order so they stay grouped.
			document.querySelectorAll('[data-slot-toggle]').forEach(function (toggle) {
				if (toggle.parentNode !== slot) slot.appendChild(toggle);
			});
		}
		function init() {
			relocateToggle();
		}

		if (!window.__headerMenuInit) {
			window.__headerMenuInit = true;
			document.addEventListener('click', function (e) {
				var btn = e.target.closest('#menu-toggle');
				if (btn) {
					var panel = document.getElementById('mobile-menu');
					if (panel && panel.hasAttribute('hidden')) openMenu();
					else closeMenu();
					return;
				}
				var panel = document.getElementById('mobile-menu');
				if (!panel || panel.hasAttribute('hidden')) return;
				// Clicking a nav link inside closes the panel.
				if (e.target.closest('#mobile-menu .mobile-link')) {
					closeMenu();
					return;
				}
				// Clicking anywhere outside the panel closes it.
				if (!e.target.closest('#mobile-menu')) {
					closeMenu();
				}
			});
			document.addEventListener('keydown', function (e) {
				if (e.key !== 'Escape') return;
				var panel = document.getElementById('mobile-menu');
				if (panel && !panel.hasAttribute('hidden')) {
					closeMenu();
					var btn = document.getElementById('menu-toggle');
					if (btn) btn.focus();
				}
			});
			window
				.matchMedia('(max-width: 720px)')
				.addEventListener('change', function () {
					closeMenu();
					relocateToggle();
				});
			document.addEventListener('astro:after-swap', init);
		}

		init();
	})();
</script>
