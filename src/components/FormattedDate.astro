---
interface Props {
	date: Date;
}

const { date } = Astro.props;
const pad = (n: number) => String(n).padStart(2, '0');
// ISO-style log timestamp (locale-neutral) — fits the logbook metadata.
const label = `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}`;
---

<time datetime={date.toISOString()}>{label}</time>
