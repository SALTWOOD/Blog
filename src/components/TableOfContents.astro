---
interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	headings: Heading[];
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{
	filtered.length > 0 && (
		<nav class="toc" aria-label="目录">
			<h2 class="toc-title">本页目录</h2>
			<ul>
				{filtered.map((h) => (
					<li class={h.depth === 3 ? 'toc-h3' : 'toc-h2'}>
						<a href={`#${h.slug}`}>{h.text}</a>
					</li>
				))}
			</ul>
		</nav>
	)
}

<style>
	.toc-title {
		font-family: var(--font-mono);
		font-size: 0.72rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--brass);
		margin: 0 0 0.8em 0;
		font-weight: 600;
	}
	.toc ul {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.toc li {
		margin: 0.1em 0;
	}
	.toc a {
		display: block;
		text-decoration: none;
		font-size: 0.84rem;
		line-height: 1.45;
		color: rgb(var(--ink-soft));
		padding: 0.2em 0 0.2em 0.5em;
		border-left: 2px solid transparent;
		transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
	}
	.toc a:hover {
		color: var(--sea);
		border-left-color: var(--brass);
		background: rgba(var(--sea-rgb), 0.05);
	}
	[data-theme='dark'] .toc a:hover {
		color: var(--brass-soft);
	}
	.toc-h3 {
		padding-left: 0.9em;
		font-size: 0.95em;
	}
</style>
