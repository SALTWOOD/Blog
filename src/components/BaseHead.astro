---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/og-default.png';
import { ANALYTICS, BACKGROUND_IMAGE_DARK, BACKGROUND_IMAGE_LIGHT, SITE_AUTHOR, SITE_TITLE } from '../consts';
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import UmamiPV from './UmamiPV.astro';
import KonamiGlass from './KonamiGlass.astro';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
	type?: 'website' | 'article';
	publishedTime?: Date;
	modifiedTime?: Date;
	author?: string;
	tags?: string[];
	section?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const {
	title,
	description,
	image = FallbackImage,
	type = 'website',
	publishedTime,
	modifiedTime,
	author = SITE_AUTHOR,
	tags = [],
	section,
} = Astro.props;

// Umami analytics is only injected when enabled in consts.ts (and both the
// script URL and website id are present). Disabled => no script, no requests.
const umami = ANALYTICS.umami;
const umamiEnabled = umami.enabled && !!umami.src && !!umami.websiteId;
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="author" content={author} />

<!-- Prevent theme flash (FOUC) -->
<script is:inline>
	const theme = localStorage.getItem('theme');
	const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
	if (theme === 'dark' || (!theme && prefersDark)) {
		document.documentElement.setAttribute('data-theme', 'dark');
	} else {
		document.documentElement.setAttribute('data-theme', 'light');
	}
</script>
<!-- First-load entrance (blur + focus-pull): once per browser session, so it
     plays when entering the site but not on every in-site navigation. The
     animation itself lives in global.css and is skipped under reduced-motion. -->
<script is:inline>
	try {
		if (!sessionStorage.getItem('pw-entered')) {
			sessionStorage.setItem('pw-entered', '1');
			document.documentElement.classList.add('page-enter');
		}
	} catch (e) {}
</script>
<!-- Background images (light/day + dark/night) — set from the constants in
     consts.ts (no runtime toggle). Inlined as static CSS custom properties so
     they are available before first paint and survive SPA swaps (they are in a
     global head <style>, which ClientRouter persists). global.css picks one per
     [data-theme]. -->
<style is:inline set:html={`:root{--bg-image-light:url("${BACKGROUND_IMAGE_LIGHT}");--bg-image-dark:url("${BACKGROUND_IMAGE_DARK}")}`}></style>
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<Font cssVariable="--font-display" preload />
<Font cssVariable="--font-body" preload />

<!-- Client-side navigation: in-site links swap <body> without a full reload.
     The <html> element (and so data-theme) persists across swaps; the
     background is a static global <style>, so it persists too. -->
<ClientRouter />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image.src, Astro.url)} />
<meta property="og:site_name" content={SITE_TITLE} />
{type === 'article' && (
	<>
		{publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
		{modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}
		<meta property="article:author" content={author} />
		{section && <meta property="article:section" content={section} />}
		{tags.map((tag) => <meta property="article:tag" content={tag} />)}
	</>
)}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={new URL(image.src, Astro.url)} />

<!-- Umami visitor analytics (toggleable via ANALYTICS.umami in consts.ts) -->
{umamiEnabled && (
	<>
		<script is:inline defer src={umami.src} data-website-id={umami.websiteId}></script>
		<!-- Report SPA navigations to Umami. astro:after-swap fires only on
		     client-side navigations (not the first load), so the initial view
		     counted by the loader above isn't double-counted. -->
		<script is:inline>
			document.addEventListener('astro:after-swap', function () {
				if (window.umami && typeof window.umami.track === 'function') {
					window.umami.track();
				}
			});
		</script>
		<!-- Per-article pageview counts on cards + article page (client-side,
		     gated again inside the component on statisticsDisplay). -->
		<UmamiPV />
	</>
)}

<!-- Hidden easter egg. Trigger: ↑ ↑ ↓ ↓ ← → ← → B A Enter panes the screen in glass. -->
<KonamiGlass />