---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	name: string;
	url: string;
	desc: string;
	avatar?: ImageMetadata;
}

const { name, url, desc, avatar } = Astro.props;
---

<a class="friend-card" href={url} target="_blank" rel="noopener noreferrer">
	{
		avatar && <Image src={avatar} width={56} height={56} alt={name} />
	}
	<div class="text">
		<h3 class="name">{name}</h3>
		<p class="desc">{desc}</p>
	</div>
</a>

<style>
	.friend-card {
		display: flex;
		gap: 0.9rem;
		align-items: center;
		text-decoration: none;
		background: var(--paper-raised);
		border: 1px solid var(--rule);
		border-left: 3px solid transparent;
		border-radius: var(--r-md);
		padding: 1rem;
		box-sizing: border-box;
		transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
	}
	.friend-card:hover {
		transform: translateY(-3px);
		box-shadow: var(--shadow-card);
		border-left-color: var(--brass);
	}
	.friend-card :global(img) {
		width: 56px;
		height: 56px;
		border-radius: 50%;
		object-fit: cover;
		flex-shrink: 0;
		border: 1px solid var(--rule);
	}
	.name {
		margin: 0 0 0.25rem;
		color: rgb(var(--ink));
		font-family: var(--font-display);
		font-size: 1.08rem;
		font-weight: 600;
		line-height: 1.3;
		transition: color 0.15s ease;
	}
	.friend-card:hover .name {
		color: var(--sea);
	}
	[data-theme='dark'] .friend-card:hover .name {
		color: var(--brass-soft);
	}
	.desc {
		margin: 0;
		color: rgb(var(--ink-soft));
		font-size: 0.88rem;
		line-height: 1.45;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
