---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
	name: string;
	url: string;
	desc: string;
	avatar: ImageMetadata;
}

const { name, url, desc, avatar } = Astro.props;
---

<a class="friend-card" href={url} target="_blank" rel="noopener noreferrer">
	<Image src={avatar} width={56} height={56} alt={name} />
	<div class="text">
		<h3 class="name">{name}</h3>
		<p class="desc">{desc}</p>
	</div>
</a>

<style>
	.friend-card {
		display: flex;
		gap: 0.85rem;
		align-items: center;
		text-decoration: none;
		background: rgba(var(--gray-light), 0.6);
		border: 1px solid rgba(var(--gray), 0.25);
		border-radius: 12px;
		padding: 1rem;
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		box-sizing: border-box;
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease,
			border-color 0.2s ease;
	}
	.friend-card:hover {
		transform: translateY(-2px);
		box-shadow: var(--box-shadow);
		border-color: rgba(var(--accent-rgb), 0.5);
	}
	.friend-card :global(img) {
		width: 56px;
		height: 56px;
		border-radius: 50%;
		object-fit: cover;
		flex-shrink: 0;
	}
	.name {
		margin: 0 0 0.25rem;
		color: rgb(var(--black));
		font-size: 1.05rem;
		line-height: 1.3;
	}
	.desc {
		margin: 0;
		color: rgb(var(--gray));
		font-size: 0.9rem;
		line-height: 1.4;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
