---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TableOfContents from '../components/TableOfContents.astro';
import Comments from '../components/Comments.astro';
import Sidebar from '../components/Sidebar.astro';
import RelatedPosts from '../components/RelatedPosts.astro';
import { articleSidebar } from '../config/sidebar';
import FallbackImage from '../assets/og-default.png';
import { SITE_TITLE } from '../consts';
import { authorPerson } from '../lib/schema';
import 'katex/dist/katex.min.css';
import '../styles/markdown.css';

interface Heading {
	depth: number;
	slug: string;
	text: string;
}

type Props = CollectionEntry<'blog'>['data'] & {
	headings?: Heading[];
	showComments?: boolean;
	readingMinutes?: number;
	wordCount?: number;
	currentId?: string;
};

const { title, description, pubDate, updatedDate, heroImage, tags = [], category, headings = [], showComments, readingMinutes = 0, wordCount = 0, currentId } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageUrl = new URL((heroImage ?? FallbackImage).src, Astro.site);

const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: title,
	description: description,
	image: imageUrl.href,
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate ?? pubDate).toISOString(),
	author: authorPerson(Astro.site),
	publisher: authorPerson(Astro.site),
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': canonicalURL.href,
	},
	keywords: tags.join(', '),
	...(category ? { articleSection: category } : {}),
};

const breadcrumbLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: SITE_TITLE,
			item: new URL('/', Astro.site).href,
		},
		...(category
			? [
					{
						'@type': 'ListItem',
						position: 2,
						name: category,
						item: new URL(`/categories/${category}/`, Astro.site).href,
					},
				]
			: []),
		{
			'@type': 'ListItem',
			position: category ? 3 : 2,
			name: title,
			item: canonicalURL.href,
		},
	],
};
---

<html lang="zh-CN">
	<head>
		<BaseHead
			title={title}
			description={description}
			type="article"
			image={heroImage ?? FallbackImage}
			publishedTime={pubDate}
			modifiedTime={updatedDate}
			tags={tags}
			section={category}
		/>
		<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
				padding: 0;
			}
			.hero-image {
				width: 100%;
				max-width: 1240px;
				margin: 0 auto;
				padding: 0 1em;
				box-sizing: border-box;
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: auto;
				margin: 0 auto;
				border-radius: var(--r-lg);
				border: 1px solid var(--rule);
				box-shadow: var(--shadow-card);
			}
			.content-wrapper {
				display: flex;
				gap: 2.25em;
				max-width: 1240px;
				margin: 0 auto;
				padding: 2.5em 1em;
				box-sizing: border-box;
				align-items: flex-start;
			}
			.prose {
				flex: 1;
				min-width: 0;
				max-width: 720px;
				margin: 0 auto;
				color: rgb(var(--ink));
			}
			.toc-sidebar {
				width: 208px;
				flex-shrink: 0;
				position: sticky;
				top: 5em;
				align-self: flex-start;
				max-height: calc(100vh - 6em);
				overflow-y: auto;
			}
			/* Left sider is hidden by its own component below 1200px; drop the
			   TOC too once the viewport can't hold a 3-column row. */
			@media (max-width: 1200px) {
				.content-wrapper {
					justify-content: center;
				}
			}
			@media (max-width: 1000px) {
				.toc-sidebar {
					display: none;
				}
				.content-wrapper {
					flex-direction: column;
					padding: 2em 1em;
				}
				/* Give the article column a definite width. Without it the column
				   is a non-stretched flex item sized to its widest child
				   (max-content), so a long code line / wide table / equation
				   stretches the whole page past the viewport and forces horizontal
				   scrolling. With width:100% those children hit a definite bound and
				   scroll inside themselves (pre/table/katex) instead. */
				.prose {
					width: 100%;
				}
			}

			/* Log-entry header */
			.entry-head {
				margin-bottom: 1.5em;
				padding-bottom: 1.25em;
				border-bottom: 1px solid var(--rule);
			}
			.entry-head .meta {
				display: flex;
				flex-wrap: wrap;
				align-items: center;
				gap: 0.5em;
				font-family: var(--font-mono);
				font-size: 0.8rem;
				letter-spacing: 0.02em;
				color: rgb(var(--ink-soft));
				margin-bottom: 0.9rem;
				text-transform: uppercase;
			}
			.entry-head .meta .cat {
				color: var(--sea);
			}
			.entry-head .meta .dot {
				color: var(--rule);
			}
			.entry-head h1 {
				margin: 0 0 0.5em 0;
				font-size: clamp(1.9rem, 4.5vw, 2.6rem);
				line-height: 1.15;
			}
			.entry-head .last-updated {
				margin: 0;
				font-size: 0.85rem;
				color: rgb(var(--ink-soft));
				font-style: italic;
				font-family: var(--font-display);
			}
			.post-meta {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
				margin-top: 1.4em;
			}
			.tag-list {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4em;
			}
			.tag-badge,
			.category-badge {
				display: inline-block;
				padding: 0.3em 0.75em;
				border-radius: var(--r-sm);
				font-family: var(--font-mono);
				font-size: 0.78em;
				letter-spacing: 0.02em;
				text-decoration: none;
				background: var(--paper-chip);
				border: 1px solid var(--rule);
				color: rgb(var(--ink-soft));
				transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
			}
			.tag-badge:hover,
			.category-badge:hover {
				background: var(--sea);
				border-color: var(--sea);
				color: #fff;
			}

			/* Inline article images get a framed chart treatment */
			.prose :global(img) {
				border: 1px solid var(--rule);
				box-shadow: var(--shadow-card);
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article id="top">
				<div class="hero-image">
					{heroImage && <Image width={1020} height={510} src={heroImage} alt={title} />}
				</div>
				<div class="content-wrapper">
					<Sidebar blocks={articleSidebar} currentId={currentId} readingMinutes={readingMinutes} wordCount={wordCount} />
					<div class="prose" data-pagefind-body>
						<header class="entry-head">
							<div class="meta">
								<FormattedDate date={pubDate} />
								{category && (
									<>
										<span class="dot">/</span>
										<span class="cat">{category}</span>
									</>
								)}
							</div>
							<h1>{title}</h1>
							{
								updatedDate && (
									<p class="last-updated">
										最后更新于 <FormattedDate date={updatedDate} />
									</p>
								)
							}
							<div class="post-meta">
								{category && <a href={`/categories/${category}`} class="category-badge">{category}</a>}
								{
									tags.length > 0 && (
										<div class="tag-list">
											{tags.map((tag) => (
												<a href={`/tags/${tag}`} class="tag-badge">#{tag}</a>
											))}
										</div>
									)
								}
							</div>
						</header>
						<slot />
						<RelatedPosts id={currentId} />
						{showComments && <Comments />}
					</div>
					<div class="toc-sidebar">
						<TableOfContents headings={headings} />
					</div>
				</div>
			</article>
		</main>
		<Footer />
		<script is:inline>
			// Markdown enhancements (Phase 2): build tab buttons from panel
			// data-titles, and add a copy button to every code block. Plain
			// vanilla JS — no framework.
			function enhanceMarkdown() {
				// Tabs
				document.querySelectorAll('.prose .tab-group').forEach((group) => {
					if (group.querySelector('.tab-list')) return;
					const panels = Array.from(group.querySelectorAll(':scope > .tab-panel'));
					if (panels.length === 0) return;
					const list = document.createElement('div');
					list.className = 'tab-list';
					list.setAttribute('role', 'tablist');
					panels.forEach((panel, i) => {
						const btn = document.createElement('button');
						btn.type = 'button';
						btn.className = 'tab-btn';
						btn.textContent = panel.dataset.title || `标签页 ${i + 1}`;
						btn.setAttribute('role', 'tab');
						btn.setAttribute('aria-selected', i === 0 ? 'true' : 'false');
						btn.addEventListener('click', () => {
							panels.forEach((p) => (p.hidden = true));
							list.querySelectorAll('.tab-btn').forEach((b) => b.setAttribute('aria-selected', 'false'));
							panel.hidden = false;
							btn.setAttribute('aria-selected', 'true');
						});
						list.appendChild(btn);
						panel.setAttribute('role', 'tabpanel');
						panel.hidden = i !== 0;
					});
					group.insertBefore(list, group.firstChild);
				});

				// Copy buttons on code blocks
				document.querySelectorAll('.prose pre').forEach((pre) => {
					if (pre.querySelector('.code-copy')) return;
					const code = pre.querySelector('code');
					if (!code) return; // skip mermaid / non-code pre
					const btn = document.createElement('button');
					btn.type = 'button';
					btn.className = 'code-copy';
					btn.setAttribute('aria-label', '复制代码');
					btn.textContent = '复制';
					btn.addEventListener('click', async () => {
						try {
							await navigator.clipboard.writeText(code.textContent ?? '');
							btn.textContent = '已复制';
						} catch {
							btn.textContent = '失败';
						}
						setTimeout(() => (btn.textContent = '复制'), 1500);
					});
					pre.appendChild(btn);
				});
			}
			// The blog has no client-side router, so run directly. This script
			// sits at the end of <body>, after the article content is parsed.
			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', enhanceMarkdown);
			} else {
				enhanceMarkdown();
			}
		</script>
	</body>
</html>
